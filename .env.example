# =========================================================
# Project Zarya Enterprise example environment
# Copy this file to .env and fill real values.
# =========================================================

# Django settings
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-generate-real-secret-key
DEBUG=False

# Hosts
# Example for local:
# ALLOWED_HOSTS=127.0.0.1,localhost
# Example for hosting:
# ALLOWED_HOSTS=your-domain.ru,www.your-domain.ru
ALLOWED_HOSTS=127.0.0.1,localhost

# CSRF trusted origins.
# Required for HTTPS domains.
# Example:
# CSRF_TRUSTED_ORIGINS=https://your-domain.ru,https://www.your-domain.ru
CSRF_TRUSTED_ORIGINS=

# Database
# Local/test SQLite:
DATABASE_URL=sqlite:///db.sqlite3

# Static and media
STATIC_ROOT=staticfiles
MEDIA_ROOT=media

# Cookies / HTTPS
# For HTTPS hosting usually set both to True.
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Project options
GITHUB_REPO=
OCR_ENABLED=True

# OCR runtime
# Local Windows examples:
# POPPLER_PATH=D:\Release-26.02.0-0\poppler-26.02.0\Library\bin
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
#
# On Linux hosting leave empty if poppler/tesseract are installed in PATH.
POPPLER_PATH=
TESSERACT_CMD=
